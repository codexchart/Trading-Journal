# Copy this file to `.env` and fill in the values from your Supabase project:
# Supabase Dashboard -> Project Settings -> API

# Public values — safe to expose in frontend code (protected by Row Level
# Security, not secrecy).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here

# Secret value — server-side / admin use ONLY (e.g. one-off migration
# scripts). NEVER ship this in frontend JS or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
